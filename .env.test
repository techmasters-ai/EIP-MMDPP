APP_ENV=test
API_PORT=8001
LOG_LEVEL=WARNING
SECRET_KEY=test-secret-key-deterministic

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=eip_test
POSTGRES_USER=eip_test
POSTGRES_PASSWORD=eip_test_secret

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=testadmin
MINIO_SECRET_KEY=testadmin
MINIO_SECURE=false
MINIO_BUCKET_RAW=eip-test-raw
MINIO_BUCKET_DERIVED=eip-test-derived

# Use lightweight models in CI (no GPU required)
TEXT_EMBEDDING_MODEL=paraphrase-MiniLM-L6-v2
TEXT_EMBEDDING_DIM=384
IMAGE_EMBEDDING_MODEL=ViT-B-32
IMAGE_EMBEDDING_PRETRAINED=openai
IMAGE_EMBEDDING_DIM=512

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VLM_MODEL=llava
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LLM provider — mock skips all real LLM/Cognee calls in tests
LLM_PROVIDER=mock
OPENAI_API_KEY=

COGNEE_GRAPH_ENGINE=networkx
COGNEE_VECTOR_ENGINE=lancedb
COGNEE_DATA_DIR=/tmp/eip-test-cognee

OCR_TESSERACT_CONFIDENCE_THRESHOLD=0.75
OCR_EASYOCR_CONFIDENCE_THRESHOLD=0.60

DEFAULT_CLASSIFICATION=UNCLASSIFIED
ABAC_POLICY_PATH=/app/policy/abac.yaml

WATCH_DIR_POLL_INTERVAL_SECONDS=5

TEST_SEED=42
TEST_TIMEOUT_SECONDS=300
KEEP_STACK=0
