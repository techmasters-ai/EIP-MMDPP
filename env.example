# ============================================================
# EIP-MMDPP — Environment Configuration
# Copy this file to .env and fill in values before running.
# ============================================================

# ---------------------------------------------------------------------------
# Docker Network (shared with Ollama/LiteLLM project)
# ---------------------------------------------------------------------------
DOCKER_NETWORK=prod_network

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
API_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eip
POSTGRES_USER=eip
POSTGRES_PASSWORD=eip_secret

# Constructed from above — override if needed
# DATABASE_URL=postgresql+asyncpg://eip:eip_secret@postgres:5432/eip
# DATABASE_URL_SYNC=postgresql+psycopg2://eip:eip_secret@postgres:5432/eip

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---------------------------------------------------------------------------
# MinIO / Object Storage
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_RAW=eip-raw
MINIO_BUCKET_DERIVED=eip-derived
MINIO_API_PORT=9010                   # Host port for MinIO API (avoid conflicts)
MINIO_CONSOLE_PORT=9011               # Host port for MinIO web console

# ---------------------------------------------------------------------------
# Embedding models (all run locally — air-gapped)
# ---------------------------------------------------------------------------
# Text embedding model (downloaded from HuggingFace on first use)
TEXT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
TEXT_EMBEDDING_DIM=1024

# Image embedding model (OpenCLIP)
IMAGE_EMBEDDING_MODEL=ViT-B-32
IMAGE_EMBEDDING_PRETRAINED=openai
IMAGE_EMBEDDING_DIM=512

# ---------------------------------------------------------------------------
# LLM Provider — system-wide (applies to ALL LLM features)
# "ollama" = air-gapped local LLM | "openai" = OpenAI API | "mock" = no LLM
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama

# Provider connection settings (used by all features for the selected provider)
OPENAI_API_KEY=sk-your-key-here        # Required when LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://ollama:11434    # Required when LLM_PROVIDER=ollama

# ---------------------------------------------------------------------------
# Per-feature model selection
# Each LLM-dependent feature can use a different model.
# ---------------------------------------------------------------------------
DOCLING_GRAPH_MODEL=llama3.2           # Model for graph entity/relationship extraction
COGNEE_MODEL=llama3.2                  # Model for Cognee memory operations

# Legacy Ollama settings (DEPRECATED — use per-feature model settings above)
OLLAMA_VLM_MODEL=llava
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# docling-graph extraction
# ---------------------------------------------------------------------------
DOCLING_GRAPH_TIMEOUT=120.0

# ---------------------------------------------------------------------------
# Memory layer (Cognee-backed governed memory)
# ---------------------------------------------------------------------------
MEMORY_ENABLED=true

# ---------------------------------------------------------------------------
# Cognee knowledge graph storage
# networkx + lancedb require no extra services (bundled with cognee)
# ---------------------------------------------------------------------------
COGNEE_GRAPH_ENGINE=networkx        # networkx | neo4j
COGNEE_VECTOR_ENGINE=lancedb        # lancedb | pgvector
COGNEE_DATA_DIR=/app/data/cognee    # local storage path for LanceDB + graph files

# ---------------------------------------------------------------------------
# Docling document conversion service (granite-docling-258M VLM)
# Replaces legacy extraction pipeline (pdfplumber, Tesseract, Ollama llava)
# ---------------------------------------------------------------------------
DOCLING_SERVICE_URL=http://docling:8001
DOCLING_TIMEOUT_SECONDS=300
DOCLING_FALLBACK_ENABLED=true         # Fall back to legacy extraction if Docling is down
DOCLING_DEVICE=cuda                   # cuda | cpu
DOCLING_DTYPE=bfloat16                # bfloat16 | float32 (use float32 for CPU)
DOCLING_PORT=8001

# ---------------------------------------------------------------------------
# OCR thresholds
# ---------------------------------------------------------------------------
OCR_TESSERACT_CONFIDENCE_THRESHOLD=0.75
OCR_EASYOCR_CONFIDENCE_THRESHOLD=0.60

# ---------------------------------------------------------------------------
# Security / ABAC
# ---------------------------------------------------------------------------
DEFAULT_CLASSIFICATION=UNCLASSIFIED
ABAC_POLICY_PATH=/app/policy/abac.yaml

# ---------------------------------------------------------------------------
# Workers
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY=4

# ---------------------------------------------------------------------------
# Directory watcher
# ---------------------------------------------------------------------------
WATCH_DIR_POLL_INTERVAL_SECONDS=30

# ---------------------------------------------------------------------------
# Testing (only used with .env.test)
# ---------------------------------------------------------------------------
# TEST_SEED=42
# TEST_TIMEOUT_SECONDS=300
# KEEP_STACK=0
