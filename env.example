# ============================================================
# EIP-MMDPP — Environment Configuration
# Copy this file to .env and fill in values before running.
# ============================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
API_PORT=8000
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eip
POSTGRES_USER=eip
POSTGRES_PASSWORD=eip_secret

# Constructed from above — override if needed
# DATABASE_URL=postgresql+asyncpg://eip:eip_secret@postgres:5432/eip
# DATABASE_URL_SYNC=postgresql+psycopg2://eip:eip_secret@postgres:5432/eip

# ---------------------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Celery Redis visibility timeout (seconds) — prevents redelivery of long tasks
CELERY_VISIBILITY_TIMEOUT=10800

# ---------------------------------------------------------------------------
# MinIO / Object Storage
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_RAW=eip-raw
MINIO_BUCKET_DERIVED=eip-derived
MINIO_API_PORT=9010                   # Host port for MinIO API (avoid conflicts)
MINIO_CONSOLE_PORT=9011               # Host port for MinIO web console

# ---------------------------------------------------------------------------
# Embedding models (all run locally — air-gapped)
# ---------------------------------------------------------------------------
# Text embedding model (downloaded from HuggingFace on first use)
TEXT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
TEXT_EMBEDDING_DIM=1024
EMBED_TEXT_BATCH_SIZE=128

# Image embedding model (OpenCLIP)
# Options:
#   ViT-B-32  / openai          / 512   (~400MB, baseline)
#   ViT-B-16  / openai          / 512   (~600MB, minor quality bump)
#   ViT-L-14  / laion2b_s32b_b82k / 768 (~1.7GB, good quality/size ratio)
#   EVA02-E-14-plus / laion2b_s9b_b144k / 1024 (~4.4GB, best quality, needs large GPU)
# NOTE: Changing dim requires Qdrant collection recreation + document reingest.
IMAGE_EMBEDDING_MODEL=ViT-B-32
IMAGE_EMBEDDING_PRETRAINED=openai
IMAGE_EMBEDDING_DIM=512

# ---------------------------------------------------------------------------
# LLM Provider — system-wide (applies to ALL LLM features)
# "ollama" = air-gapped local LLM | "openai" = OpenAI API | "mock" = no LLM
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama

# Provider connection settings (used by all features for the selected provider)
OPENAI_API_KEY=sk-your-key-here        # Required when LLM_PROVIDER=openai
OPENAI_BASE_URL=                       # Custom OpenAI-compatible endpoint (leave empty for default)
OLLAMA_BASE_URL=http://ollama:11434    # Required when LLM_PROVIDER=ollama
OLLAMA_NUM_CTX=16384                   # Context window size for Ollama models
OLLAMA_THINK=                          # Thinking level for gpt-oss: low, medium, high (empty = disabled)
LLM_MAX_TOKENS=64000                   # Max output tokens for LLM calls (thinking models need high values)

# ---------------------------------------------------------------------------
# Document Analysis (LLM metadata extraction after Docling conversion)
# ---------------------------------------------------------------------------
DOC_ANALYSIS_ENABLED=true
DOC_ANALYSIS_LLM_MODEL=llama3.1:latest
DOC_ANALYSIS_TIMEOUT=300
DOC_ANALYSIS_SUMMARY_PROMPT="Summarize this document in 5-6 sentences for a technical reader. Focus on the main subject, scope, and notable findings. Do not include source endnote markings such as [1]."
DOC_ANALYSIS_DATE_PROMPT="Extract the most relevant date of information (publication date, report date, or coverage window). If only month/year appears, return that. If there is a range, return it exactly. If unsure, return Unknown. Provide ONLY the date or range."
DOC_ANALYSIS_SOURCE_PROMPT="Characterize the source: 1) Organization or author (if unknown return UNKNOWN) 2) Type of information (website, journal, etc; if unknown return UNKNOWN) 3) Reliability score 1-10. Format: Organization: <name>\nType: <type>\nReliability: <score>/10"
DOC_ANALYSIS_CLASSIFICATION_PROMPT="Identify the document classification marking if present (UNCLASSIFIED, CUI, FOUO, SECRET, TOP SECRET). If none, reply UNCLASSIFIED. Provide ONLY the marking."

# ---------------------------------------------------------------------------
# Picture Description (post-conversion via Ollama, uses document summary as context)
# ---------------------------------------------------------------------------
PICTURE_DESCRIPTION_MODEL=gemma3:27b
PICTURE_DESCRIPTION_TIMEOUT=120
PICTURE_DESC_SOFT_TIME_LIMIT=10800
PICTURE_DESC_TIME_LIMIT=10980
PICTURE_DESCRIPTION_PROMPT="You are a senior all-source scientific and technical intelligence analyst with deep expertise in military missiles, air and missile defense systems, radars, launchers, fire-control systems, RF/sensor payloads, guidance and control, telemetry, flight test instrumentation, and supporting ground equipment. Your task is to analyze one image extracted from a multimodal PDF as if it were being prepared for professional intelligence exploitation. Source-Use Rule: Use the PDF Summary and Image Summary for contextual orientation, terminology, and possible relevance, but base all technical judgments primarily on what is visually observable in the image. Visual evidence always takes priority. If the PDF Summary or Image Summary suggests something not supported by the image, explicitly note the mismatch and prioritize the visible evidence. Primary Objective: Classify the image into exactly one category from this controlled list: docs_handwritten, engineering_drawing, block_diagram, raw_signal_data, charts_graphs, photo. Then produce a full-spectrum technical exploitation report that is exhaustive, disciplined, and intelligence-focused. Account for every visible element in the image, even if seemingly minor. Prioritize: 1. Physical characteristics 2. Scientific and technical characteristics 3. Performance-related indicators inferable from visible evidence 4. System function, role, and possible identity 5. Confidence levels and analytic caveats. Analytic Rules: Always continue the full analysis regardless of confidence. Never guess unreadable text, ambiguous symbols, or hidden details; record them in Uncertainty. Clearly distinguish among: Direct observation: what is visibly present; Context-informed assessment: what is supported by the image and consistent with the PDF/Image summaries; Reasoned inference: what is likely based on visible evidence; Low-confidence speculation: possible but unconfirmed interpretations. Do not invent markings, dimensions, capabilities, or identities that are not supported by the image. Do not treat the PDF Summary or Image Summary as proof of identity, function, or performance. If exact identification is uncertain, provide the most likely possibilities and explain the visual basis for each. If relevant, state whether the image appears consistent with, partially consistent with, or in tension with the PDF Summary and/or Image Summary. Use precise technical language appropriate for defense and intelligence analysts. Keep numbers to sensible precision (<=3 significant figures unless shown otherwise). Record units in SI where applicable. Quote OCR verbatim when possible. If the image contains non-English or foreign-language text, transcribe the visible text as accurately as possible and provide an English translation in the relevant sections, clearly marking any uncertain words or characters. Include translated foreign-language text in the General Description, OCR, Category-Specific Details, and Analyst Notes when it materially helps interpretation. Do not identify people; only count faces if present. Shortlist the top 3 plausible categories, choose 1 winner, and report the alternates with rationale. Populate only the category-specific subsection matching the selected category. Always complete all 8 sections below. Output Format: Use these exact section headers and structure: 1) Classification: Category=<one category from the controlled list>; Confidence (0-1)=<value>; Alternates=<top 2 alternate categories with brief rationale>. 2) Why This Category (Evidence): Justify the selected category using visible cues such as layout, symbology, axes, legends, title blocks, handwriting, arrows, connectors, grids, instrument traces, scene composition, vehicle/system geometry, radar/sensor features, or launcher/missile characteristics. Reference the PDF Summary and Image Summary only when they help disambiguate. 3) General Description: Provide 1-3 sentences describing the image in missile/radar/S&T/intelligence terms, including likely subject matter, visible role/function, and why the image is analytically relevant. If foreign-language text is present and relevant, include its English meaning in the description. 4) OCR: Has Text=yes/no; Legibility=good|medium|poor; Verbatim Text=<short exact high-signal text, or (none)>; Translation=<English translation of any foreign-language text, or (none)>. 5) Category-Specific Details: Fill only the subsection matching the chosen category. For docs_handwritten: Document Type; Key Fields/Headings Seen; Dates/Times; Units/Notations; Entities/Identifiers; Signatures/Initials; Language; Remarks. For engineering_drawing: Title/Drawing No./Rev; Scale & Units; Projection; Dimensions & Tolerances; Materials/Finish/Notes; Title Block Highlights; Subsystem Relevance. For block_diagram: Main Blocks; Signal/Control Paths; I/O; Hierarchy; Notable Acronyms; Function Summary. For raw_signal_data: Display Type; Freq/Band; Timebase/Span; Vertical/Amplitude Scale; Measured/Shown Values; Channels/Overlays; Instrument/Model; Observations. For charts_graphs: Chart Type; Title & Axes; Series & Legend; Extracted Example Points; Notable Trends/Extrema; Relevance to Domain. For photo: Scene; Primary Subjects; Objects/Features (top 5); Text in Scene (no PII); Faces=count only; Safety/PPE; Context Cues. In addition, when relevant to the selected category, integrate domain-specific technical detail such as: missile/interceptor class cues; fin/control surface layout; canister/rail/tube/launcher clues; radar/sensor antenna geometry; fire-control or tracking indicators; waveguides/cabling/power/cooling cues; telemetry/test instrumentation features; support vehicle, chassis, outrigger, or deployment clues; engineering or systems-function relevance to missile/radar/S&T workflows. 6) Extracted Technical Takeaways: Provide 5-10 concise bullets containing the most decision-useful technical facts. Make units explicit and SI-preferred. Focus on observed features, supported assessments, and performance-relevant indicators that can be reasonably inferred. 7) Uncertainty: Note unreadable regions, occlusions, low resolution, angle limitations, ambiguous symbols, incomplete scale, hidden components, and anything that cannot be confirmed visually. Also note any possible bias or mismatch introduced by the PDF Summary or Image Summary. For foreign-language text, note any uncertain transcription or translation. 8) Analyst Notes: Write 5-7 concise sentences explaining: how the PDF Summary and Image Summary influenced interpretation; whether they were consistent with the image; key caveats affecting confidence; the most likely intelligence significance; the next best analytical step or additional collection needed. Include any important implications of translated foreign-language text if relevant. Final Instruction: Produce a complete exploitation-oriented report suitable for downstream intelligence analysis. Ensure every visible detail in the image is addressed somewhere in the output. Integrate the PDF Summary and Image Summary only as contextual support, never as a substitute for visual analysis. Inputs: - PDF Summary: {document_summary} - Image: [insert image here]"
# ---------------------------------------------------------------------------
# Translation (foreign language detection + LLM translation)
# ---------------------------------------------------------------------------
TRANSLATION_ENABLED=true
TRANSLATION_MODEL=gpt-oss:120b
TRANSLATION_TIMEOUT=300
TRANSLATION_SOFT_TIME_LIMIT=3600
TRANSLATION_TIME_LIMIT=3660

# ---------------------------------------------------------------------------
# Docling OCR
# ---------------------------------------------------------------------------
DOCLING_OCR_LANG=en

# ---------------------------------------------------------------------------
# Docling-Graph Service — ontology-driven entity/relationship extraction
# ---------------------------------------------------------------------------
DOCLING_GRAPH_LLM_PROVIDER=ollama
DOCLING_GRAPH_LLM_MODEL=llama3.1:latest
DOCLING_GRAPH_LLM_TIMEOUT=10800
DOCLING_GRAPH_PORT=8002
DOCLING_GRAPH_BASE_URL=http://docling-graph:8002
DOCLING_GRAPH_CONCURRENCY=2
DOCLING_GRAPH_TIMEOUT=300

# Graph extraction chunking
# Entity extraction text chunking (chars). Most documents fit in one chunk.
# Only very large documents (>100K chars) will be chunked. Overlap ensures
# entities near chunk boundaries are captured in at least one chunk.
GRAPH_EXTRACTION_CHUNK_SIZE=100000
GRAPH_EXTRACTION_CHUNK_OVERLAP=2000

# Graph extraction confidence
DOCLING_REVIEW_CONFIDENCE_THRESHOLD=0.60

# Graph confidence quality gates
GRAPH_NODE_MIN_CONFIDENCE=0.60
GRAPH_REL_MIN_CONFIDENCE=0.55

# ---------------------------------------------------------------------------
# Neo4j — knowledge graph
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=eip_neo4j_secret
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474

# ---------------------------------------------------------------------------
# Qdrant — vector search
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_TEXT_COLLECTION=eip_text_chunks
QDRANT_IMAGE_COLLECTION=eip_image_chunks
QDRANT_TRUSTED_TEXT_COLLECTION=eip_trusted_text
QDRANT_UPSERT_BATCH_SIZE=128
QDRANT_TIMEOUT_SECONDS=60
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ---------------------------------------------------------------------------
# GraphRAG — community detection + reports
# ---------------------------------------------------------------------------
GRAPHRAG_LLM_PROVIDER=ollama
GRAPHRAG_LLM_MODEL=llama3.1:latest
GRAPHRAG_LLM_API_BASE=http://ollama:11434/v1
GRAPHRAG_API_KEY=                      # Required when GRAPHRAG_LLM_PROVIDER=openai
GRAPHRAG_EMBEDDING_MODEL=bge-m3:latest
GRAPHRAG_LLM_TIMEOUT=10800
GRAPHRAG_INDEXING_ENABLED=true
GRAPHRAG_INDEXING_INTERVAL_MINUTES=60
GRAPHRAG_MAX_CLUSTER_SIZE=10

# ---------------------------------------------------------------------------
# Docling document conversion service (granite-docling-258M VLM)
# ---------------------------------------------------------------------------
DOCLING_SERVICE_URL=http://docling:8001
DOCLING_TIMEOUT_SECONDS=300
DOCLING_DEVICE=cuda                   # cuda | cpu
DOCLING_DTYPE=bfloat16                # bfloat16 | float32 (use float32 for CPU)
DOCLING_PORT=8001

# ---------------------------------------------------------------------------
# Workers
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY=4
# Split worker concurrency (used with docker compose --profile split)
WORKER_INGEST_CONCURRENCY=4
WORKER_EMBED_CONCURRENCY=2
WORKER_GRAPH_CONCURRENCY=2

# ---------------------------------------------------------------------------
# Pipeline retry & time-limit settings
# ---------------------------------------------------------------------------
PREPARE_MAX_RETRIES=10
PREPARE_RETRY_DELAY=120
PREPARE_SOFT_TIME_LIMIT=1800
PREPARE_TIME_LIMIT=1860
EMBED_MAX_RETRIES=10
EMBED_RETRY_DELAY=120
EMBED_SOFT_TIME_LIMIT=600
EMBED_TIME_LIMIT=660
GRAPH_MAX_RETRIES=10
GRAPH_RETRY_DELAY=120
GRAPH_SOFT_TIME_LIMIT=1800
GRAPH_TIME_LIMIT=1860
FINALIZE_MAX_RETRIES=10
FINALIZE_RETRY_DELAY=120
FINALIZE_SOFT_TIME_LIMIT=600
FINALIZE_TIME_LIMIT=660
DOCLING_CONCURRENCY=1
DOCLING_LOCK_TIMEOUT=1800
DOCLING_HEALTH_TIMEOUT=5.0
# In-task 503 retry cap (Docling busy with prior conversion, default 20 ~37 min)
DOCLING_503_MAX_RETRIES=20

# Singleflight lock timeout for prepare_document (seconds)
PREPARE_SINGLEFLIGHT_TIMEOUT=5400

# ---------------------------------------------------------------------------
# Retrieval Scoring — Weighted Fusion (all configurable via env vars)
# ---------------------------------------------------------------------------
# Score fusion weights (must sum to 1.0)
RETRIEVAL_SEMANTIC_WEIGHT=0.65
RETRIEVAL_DOC_STRUCTURE_WEIGHT=0.20
RETRIEVAL_ONTOLOGY_WEIGHT=0.15

# Retrieval diversity (content-level dedup)
RETRIEVAL_DIVERSITY_OVERSAMPLE_FACTOR=8
RETRIEVAL_DIVERSITY_MAX_CANDIDATES=800

# Document-structure link weights (chunk_links table)
RETRIEVAL_WEIGHT_NEXT_CHUNK=0.90
RETRIEVAL_WEIGHT_SAME_SECTION=0.88
RETRIEVAL_WEIGHT_SAME_ARTIFACT=0.82
RETRIEVAL_WEIGHT_SAME_PAGE=0.78

# Expansion limits
RETRIEVAL_DOC_EXPAND_K=5
RETRIEVAL_DOC_MAX_HOPS=2
RETRIEVAL_ONTOLOGY_EXPAND_K=5

# Hop penalty and bonuses
RETRIEVAL_HOP_PENALTY_BASE=0.92
RETRIEVAL_MIL_ID_BONUS=0.03

# Legacy decay (fallback for pre-v2 documents without chunk_links)
RETRIEVAL_CROSS_MODAL_DECAY=0.85
RETRIEVAL_ONTOLOGY_DECAY=0.75

# ---------------------------------------------------------------------------
# Reranker (cross-encoder for retrieval re-scoring)
# ---------------------------------------------------------------------------
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu                     # cpu | cuda
RERANKER_ENABLED=true
RERANKER_TOP_N=10

# Minimum cosine similarity for results (below this, results are dropped)
RETRIEVAL_MIN_SCORE_THRESHOLD=0.25

# ---------------------------------------------------------------------------
# Directory watcher
# ---------------------------------------------------------------------------
WATCH_DIR_POLL_INTERVAL_SECONDS=30

# ---------------------------------------------------------------------------
# Testing (only used with .env.test)
# ---------------------------------------------------------------------------
# TEST_SEED=42
# TEST_TIMEOUT_SECONDS=300
# KEEP_STACK=0
